NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/smartdtc?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=1d
REFRESH_TOKEN_SECRET=change_this_refresh_secret_too
REFRESH_EXPIRES_IN=7d

# Python AI Microservice
PYTHON_AI_URL=http://localhost:8000
AI_SERVICE_URL=http://localhost:8000

# Frontend origin (CORS)
CLIENT_URL=http://localhost:3000

# Redis (optional – for rate limiting store)
REDIS_URL=redis://localhost:6379

# Email (Nodemailer / SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# CSV dataset paths (used by seeder scripts)
ROUTES_CSV_PATH=../data/routes.csv
STAGES_CSV_PATH=../data/stages.csv
